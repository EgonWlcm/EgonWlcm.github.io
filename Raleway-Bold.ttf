header {

    background: linear-gradient(rgba(0, 0, 0, 0.61), rgba(0, 0, 0, 0.61)), url(../beelden/header.png);
    background-size: cover;
    width: 100%;
    display: flex;
}

header aside {

    width: 60%;
    display: flex;
    justify-content: flex-end;
    align-items: flex-end;
    padding-top: 6%;
    padding-bottom: 30%;
}

header aside a {

    width: 30%;
}

header aside a img {

    width: 100%;
}

header nav {

    width: 40%;
    display: flex;
    justify-content: flex-start;
    padding: 1% 4% 4% 4%;
    padding-bottom: 40%;
}

header nav ul {

    width: 70%;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
}

header nav ul a {

    color: white;
}

figure {

    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    grid-template-rows: 1fr 2fr 2fr 1fr 0.5fr 0.5fr 0.5fr 0.5fr;
    grid-gap: 20px;
}

figure img {

    color: black;
    width: 100%;
}

figure img:nth-child(1) {
    
    grid-row: 1;
    grid-column: 1;
}

figure img:nth-child(6) {
    
    grid-row: 2;
    grid-column: 1/5;
}

figure img:nth-child(7) {
    
    grid-row: 3;
    grid-column: 1/3;
}

figure img:nth-child(8) {
    
    grid-row: 3;
    grid-column: 3/5;
}

figure img:nth-child(10) {
    
    grid-row: 6/9;
    grid-column: 1/3;
}


figure img:nth-child(11) {
    
    grid-row: 4/6;
    grid-column: 3/5;
}

figure img:nth-child(12) {
    
    grid-row: 4;
    grid-column: 1/2;
}

figure img:nth-child(13) {
    
    grid-row: 6/7;
    grid-column: 3/5;
}

figure img:nth-child(13) {
    
    grid-row: 7/8;
    grid-column: 3/4;
}







